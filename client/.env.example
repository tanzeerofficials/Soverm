# Clerk auth (required)
VITE_CLERK_PUBLISHABLE_KEY=

# API base URL (required)
VITE_API_URL=http://localhost:5000

# PostHog analytics (optional — leave blank to disable in local dev)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Set to "true" only when you want session replay in PostHog
VITE_POSTHOG_SESSION_RECORDING=

# Sentry error reporting (optional — leave blank to disable)
VITE_SENTRY_DSN=
