# Clerk auth (required)
VITE_CLERK_PUBLISHABLE_KEY=

# API base URL (required)
VITE_API_URL=http://localhost:5000

# PostHog analytics (optional — leave blank to disable in local dev)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Set to "true" only when you want session replay in PostHog
VITE_POSTHOG_SESSION_RECORDING=

# Sentry error reporting (optional — leave blank to disable)
VITE_SENTRY_DSN=

# Read-only demo mode (optional). 1 = show the "View live demo" CTA on the
# landing page. The API must also run with DEMO_MODE=1 (see server/.env.example)
# and be seeded via `npm run seed:demo`.
VITE_DEMO_MODE=

# Content-Security-Policy for production is set on Vercel (client/vercel.json).
# Source of truth: client/src/lib/contentSecurityPolicy.js
# After changing the allowlist, run: npm run csp:sync
# If your API is not on *.up.railway.app, pass it when syncing:
#   VITE_API_URL=https://your-api.example.com npm run csp:sync
