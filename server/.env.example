# Server port (default 5000)
PORT=5000

# PostgreSQL
DATABASE_URL=

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Anthropic (insights + chat)
ANTHROPIC_API_KEY=

# Comma-separated browser origins for CORS (required for production / Railway)
# Example: https://soverm.vercel.app,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional
SENTRY_DSN=

# API Content-Security-Policy (Helmet). Default is enforce with default-src 'none'.
# Set to true to send Content-Security-Policy-Report-Only instead (debug only).
CSP_REPORT_ONLY=

# Stripe (Soverm Pro checkout)
# Required for upgrade CTAs / Customer Portal. Leave blank only for local free-tier work.
# Confirm at boot logs: [integrations] stripe: configured
# Or GET / → { "integrations": { "stripe": true } }
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Public app URL for Checkout success/cancel redirects (no trailing slash)
APP_BASE_URL=http://localhost:5173

# Calendar month for trackers / savings / safe-to-spend (IANA timezone)
APP_TIMEZONE=America/New_York

# Weekly truth letter + month-end letter email (Resend)
# Both required or emails dry-run to server logs (in-app notifications still fire).
# Confirm at boot: [integrations] email: configured
# Or GET / → { "integrations": { "email": true } }
RESEND_API_KEY=
MAIL_FROM=Soverm <hello@yourdomain.com>
