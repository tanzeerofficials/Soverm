# Server port (default 5000)
PORT=5000

# Set to production on Railway. Missing this used to expose /test-db when
# combined with the old NODE_ENV !== 'production' gates.
NODE_ENV=development

# Opt-in local helpers: /test-db, /sentry-test, /protected, and auto-allow
# localhost CORS. Never set to 1 on Railway production.
ENABLE_DEV_ENDPOINTS=1

# PostgreSQL
# Prefer sslmode=require on Railway public URLs. Production also enables SSL
# in code unless DATABASE_SSL=0. If the driver rejects Railway's cert chain,
# set DATABASE_SSL_REJECT_UNAUTHORIZED=0.
DATABASE_URL=
DATABASE_SSL=
DATABASE_SSL_REJECT_UNAUTHORIZED=

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# 32-byte key for encrypting Plaid access tokens at rest.
# Must be exactly 64 hex chars OR base64 that decodes to 32 bytes.
# Generate: openssl rand -hex 32
# Arbitrary passphrases are rejected (no unsalted SHA-256 fallback).
# Without this, tokens are stored in plaintext (local/dev only).
PLAID_TOKEN_ENCRYPTION_KEY=

# Anthropic (insights + chat)
ANTHROPIC_API_KEY=

# Comma-separated browser origins for CORS (required for production / Railway)
# Example: https://soverm.vercel.app,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional
SENTRY_DSN=

# Read-only investor/product demo (see middleware/demoMode.js).
# 1 = requests with header "x-soverm-demo: 1" browse the seeded demo user
# (npm run seed:demo). Leave unset in normal production deployments.
DEMO_MODE=

# Process mode (see queue/index.js, queue/boss.js). 1 = this process runs
# ONLY pg-boss queue workers, no HTTP listener — lets you scale a dedicated
# worker service independently of the web service. Leave unset for the
# default single-service mode (HTTP + queue workers in one process), which
# is what Railway's single-service deploy needs. Reuses DATABASE_URL — no
# separate queue infra required.
WORKER_MODE=

# API Content-Security-Policy (Helmet). Default is enforce with default-src 'none'.
# Set to true to send Content-Security-Policy-Report-Only instead (debug only).
CSP_REPORT_ONLY=

# Stripe (Soverm Pro checkout)
# Required for upgrade CTAs / Customer Portal. Leave blank only for local free-tier work.
# Confirm at boot logs: [integrations] stripe: configured
# Or GET / → { "integrations": { "stripe": true } }
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Public app URL for Checkout success/cancel redirects (no trailing slash)
APP_BASE_URL=http://localhost:5173

# Calendar month for trackers / savings / safe-to-spend (IANA timezone)
APP_TIMEZONE=America/New_York

# Ask Soverm finance snapshot cache (process memory + users.chat_context_epoch).
# Set to 0 to always rebuild (useful when debugging multi-replica staleness).
CHAT_FINANCIAL_SNAPSHOT_CACHE=1

# Weekly truth letter + month-end letter email (Resend)
# Both required or emails dry-run to server logs (in-app notifications still fire).
# Confirm at boot: [integrations] email: configured
# Or GET / → { "integrations": { "email": true } }
RESEND_API_KEY=
MAIL_FROM=Soverm <hello@yourdomain.com>
